{
  "name": "cue-windows",
  "version": "0.2.1",
  "description": "Windows 11 AI overlay with screen context, microphone input, and system-audio loopback.",
  "license": "GPL-3.0-or-later",
  "author": "cue contributors",
  "main": "main.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "electron .",
    "check": "node --check main.js && node --check preload.js && node --check renderer/icons.js && node --check renderer/renderer.js && node --check src/llm.js && node --check src/platform.js && node --check src/prompts.js && node --check src/screen.js && node --check src/settings.js && node --check src/store.js && node --check src/stt.js && node --check src/wav.js",
    "test": "npm run check && node --test",
    "pack": "electron-builder --dir",
    "pack:win": "electron-builder --win dir --x64",
    "dist:mac": "electron-builder --mac zip",
    "dist:win": "electron-builder --win nsis zip --x64",
    "dist:win:arm64": "electron-builder --win nsis zip --arm64"
  },
  "build": {
    "appId": "io.github.oranegonzales.cue.windows",
    "productName": "cue",
    "asar": true,
    "artifactName": "cue-windows-11-${version}-${arch}.${ext}",
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "renderer/**/*"
    ],
    "mac": {
      "target": [
        "zip"
      ],
      "category": "public.app-category.productivity",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "identity": null,
      "extendInfo": {
        "LSUIElement": true,
        "NSMicrophoneUsageDescription": "cue transcribes your microphone so it can help you in conversations.",
        "NSCameraUsageDescription": "cue does not use the camera.",
        "NSAudioCaptureUsageDescription": "cue captures audio to transcribe a conversation."
      }
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ],
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "cue"
    }
  },
  "keywords": [
    "electron",
    "windows-11",
    "overlay",
    "ai",
    "assistant",
    "system-audio"
  ],
  "devDependencies": {
    "electron": "43.1.1",
    "electron-builder": "^26.15.3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.111.0",
    "@google/genai": "^2.12.0",
    "openai": "^6.47.0"
  }
}
